<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="32dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wİ-Fİ KONTROL"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/btnWifiAyar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="Wİ-Fİ PANELİNİ AÇ"
        android:textColor="#FFFFFF"
        android:backgroundTint="#7E57C2"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:cornerRadius="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Modern Android cihazlarda Wi-Fi durumu doğrudan değiştirilemediği için sistem paneli üzerinden işlem yapılmaktadır."
        android:textColor="#888888"
        android:textAlignment="center"
        android:textStyle="italic"
        android:lineSpacingExtra="4dp"
        android:textSize="14sp" />

</LinearLayout>