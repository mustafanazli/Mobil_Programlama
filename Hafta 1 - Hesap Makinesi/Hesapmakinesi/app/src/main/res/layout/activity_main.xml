<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    tools:ignore="all">

    <LinearLayout
        android:id="@+id/displayLayout"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:background="#BFDBFE"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toTopOf="@id/grid"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed">

        <TextView
            android:id="@+id/txtHistory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="bottom|end"
            android:text=""
            android:textColor="#4B5563"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/txtDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom|end"
            android:maxLines="1"
            android:text="0"
            android:textColor="#1F2937"
            android:textSize="48sp"
            android:textStyle="bold"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="16sp"
            app:autoSizeMaxTextSize="48sp"
            app:autoSizeStepGranularity="2sp"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/grid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5"
        android:padding="10dp"
        android:useDefaultMargins="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/displayLayout">

        <Button android:id="@+id/btnPercent" android:text="%"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#000000" android:textColor="#FFFFFF" android:textSize="18sp"
            tools:ignore="HardcodedText" />

        <Button android:id="@+id/btnInv" android:text="1/x"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#000000" android:textColor="#FFFFFF" android:textSize="18sp"
            tools:ignore="HardcodedText" />

        <Button android:id="@+id/btnPow" android:text="xʸ"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#000000" android:textColor="#FFFFFF" android:textSize="18sp" />

        <Button android:id="@+id/btnSqrt" android:text="√x"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#000000" android:textColor="#FFFFFF" android:textSize="18sp" />

        <Button android:id="@+id/btn7" android:text="7"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textSize="22sp" />

        <Button android:id="@+id/btn8" android:text="8"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textSize="22sp" />

        <Button android:id="@+id/btn9" android:text="9"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textSize="22sp" />

        <Button android:id="@+id/btnPlus" android:text="+"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#000000" android:textColor="#FFFFFF" android:textSize="26sp" />

        <Button android:id="@+id/btn4" android:text="4"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textSize="22sp" />

        <Button android:id="@+id/btn5" android:text="5"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textSize="22sp" />

        <Button android:id="@+id/btn6" android:text="6"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textSize="22sp" />

        <Button android:id="@+id/btnMinus" android:text="-"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#000000" android:textColor="#FFFFFF" android:textSize="26sp" />

        <Button android:id="@+id/btn1" android:text="1"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textSize="22sp" />

        <Button android:id="@+id/btn2" android:text="2"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textSize="22sp" />

        <Button android:id="@+id/btn3" android:text="3"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textSize="22sp" />

        <Button android:id="@+id/btnMul" android:text="*"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#000000" android:textColor="#FFFFFF" android:textSize="26sp" />

        <Button android:id="@+id/btn0" android:text="0"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textSize="22sp" />

        <Button android:id="@+id/btnC" android:text="C"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#000000" android:textColor="#FFFFFF" android:textSize="22sp" />

        <Button android:id="@+id/btnEq" android:text="="
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#000000" android:textColor="#FFFFFF" android:textSize="26sp" />

        <Button android:id="@+id/btnDiv" android:text="/"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1"
            android:backgroundTint="#000000" android:textColor="#FFFFFF" android:textSize="26sp" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>