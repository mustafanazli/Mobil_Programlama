<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SensorUygulamasi" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.SensorUygulamasi" parent="Base.Theme.SensorUygulamasi" />

    <!-- Simple Minimal Button Style -->
    <style name="SensorButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="backgroundTint">@color/bg_item</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- Simple Minimal Card Style -->
    <style name="SensorCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_item</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="android:layout_margin">24dp</item>
    </style>
</resources>